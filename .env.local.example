# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# Generate with: npx auth secret
AUTH_SECRET=

# Google OAuth client — create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI (dev): http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Gemini API key (free tier) — create at https://aistudio.google.com/apikey
# Server-only: never expose this with a NEXT_PUBLIC_ prefix.
GEMINI_API_KEY=
